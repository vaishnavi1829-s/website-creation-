<svg xmlns="http://www.w3.org/2000/svg" width="400" height="600" viewBox="0 0 400 600">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1a0a0a"/>
      <stop offset="100%" stop-color="#8b0000"/>
    </linearGradient>
    <linearGradient id="overlay" x1="0" y1="1" x2="0" y2="0">
      <stop offset="0%" stop-color="#000" stop-opacity="0.9"/>
      <stop offset="40%" stop-color="#000" stop-opacity="0"/>
    </linearGradient>
    <filter id="glow"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
  </defs>
  <rect width="400" height="600" fill="url(#bg)"/>
  <rect x="10" y="10" width="380" height="8" rx="4" fill="rgba(255,255,255,0.1)"/>
  <circle cx="10" cy="14" r="6" fill="#8b0000" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
  <circle cx="390" cy="14" r="6" fill="#8b0000" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
  <rect x="10" y="582" width="380" height="8" rx="4" fill="rgba(255,255,255,0.1)"/>
  <circle cx="10" cy="586" r="6" fill="#8b0000" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
  <circle cx="390" cy="586" r="6" fill="#8b0000" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
  <text x="200" y="180" text-anchor="middle" font-size="72" filter="url(#glow)">🎬</text>
  <text x="200" y="230" text-anchor="middle" fill="#fff" font-size="22" font-weight="800" font-family="sans-serif" letter-spacing="1">Leo</text>
  <text x="240" y="318" text-anchor="middle" fill="#FFD700" font-size="30" font-weight="800" font-family="sans-serif">★ 7.4</text>
  <rect x="60" y="370" width="130" height="28" rx="14" fill="rgba(255,255,255,0.1)"/>
  <text x="125" y="389" text-anchor="middle" fill="#ccc" font-size="13" font-weight="600" font-family="sans-serif">Tamil</text>
  <rect x="210" y="370" width="130" height="28" rx="14" fill="rgba(255,255,255,0.1)"/>
  <text x="275" y="389" text-anchor="middle" fill="#ccc" font-size="13" font-weight="600" font-family="sans-serif">Action</text>
  <text x="200" y="430" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="14" font-family="sans-serif">2h 43m  •  2023</text>
  <rect x="110" y="470" width="180" height="44" rx="22" fill="#e63946" filter="url(#glow)"/>
  <text x="200" y="497" text-anchor="middle" fill="#fff" font-size="16" font-weight="700" font-family="sans-serif">BOOK NOW ▸</text>
  <text x="200" y="560" text-anchor="middle" fill="rgba(255,255,255,0.3)" font-size="11" font-family="sans-serif">CineBook Official</text>
  <rect width="400" height="600" fill="url(#overlay)" opacity="0.3"/>
</svg>